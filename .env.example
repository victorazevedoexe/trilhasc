# Variáveis de ambiente — Trilhas Inova 3
# Copie este arquivo para .env e preencha os valores

# Turso (banco de dados SQLite na nuvem)
TURSO_DATABASE_URL=libsql://seu-banco.turso.io
TURSO_AUTH_TOKEN=seu_token_aqui

# Uploadthing (armazenamento de arquivos)
UPLOADTHING_TOKEN=seu_token_uploadthing_aqui

# JWT (gere strings aleatórias longas — ex: openssl rand -hex 32)
JWT_SECRET=troque_por_string_aleatoria_longa_de_64_chars
JWT_REFRESH_SECRET=troque_por_outra_string_aleatoria_longa_de_64_chars

# Opcional
FRONTEND_URL=https://seu-app.vercel.app
PROGRAMA_DURACAO_SEMANAS=12
NODE_ENV=production
