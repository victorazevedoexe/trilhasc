{
  "version": 2,
  "buildCommand": "cd client && npm install --include=dev && npm run build",
  "outputDirectory": "client/dist",
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "api/uploadthing.js": { "maxDuration": 60 },
    "api/index.js": { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/api/uploadthing", "destination": "/api/uploadthing.js" },
    { "source": "/api/uploadthing/:path*", "destination": "/api/uploadthing.js" },
    { "source": "/api/:path*", "destination": "/api/index.js" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
